APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Post-session coaching (Laravel uses this for transcript analysis — same key as agent is fine locally)
OPENAI_API_KEY=
OPENAI_FEEDBACK_MODEL=gpt-4o

# Feedback page (0–10 scores): weak if score < WEAK_BELOW; strong if score >= STRONG_FROM; mid between.
FEEDBACK_SCORE_TIER_WEAK_BELOW=5
FEEDBACK_SCORE_TIER_STRONG_FROM=7
FEEDBACK_SCORE_LABEL_WEAK="Needs focus"
FEEDBACK_SCORE_LABEL_MID="Mixed signal"
FEEDBACK_SCORE_LABEL_STRONG="Strong signal"

DEFAULT_INTERVIEW_MODE=simulation
# Used only if duration-based primary count cannot be derived; normal flow uses duration + INTERVIEW_MINUTES_PER_PRIMARY_QUESTION.
DEFAULT_INTERVIEW_QUESTION_COUNT=6
DEFAULT_INTERVIEW_DURATION_MINUTES=25
# Primary topics for the AI agent (~ ceil(duration_minutes / this); clamped min/max below)
INTERVIEW_MINUTES_PER_PRIMARY_QUESTION=2.5
INTERVIEW_PRIMARY_QUESTION_MIN=4
INTERVIEW_PRIMARY_QUESTION_MAX=20

# LiveKit web client + token issuance integration
VITE_LIVEKIT_URL=ws://localhost:7880
VITE_TOKEN_SERVER_URL=http://localhost:5001
LIVEKIT_TOKEN_SERVER_URL=http://localhost:5001
LIVEKIT_INTERNAL_TOKEN_SECRET=
# Base URL Laravel uses when generating signed CV/callback URLs for the Python containers.
# MUST match APP_URL hostname so signatures validate. With Docker Compose, tokens/agent use
# `extra_hosts: titin.ai.test:host-gateway` so this URL is reachable inside containers.
PYTHON_ACCESSIBLE_APP_URL=https://titin.ai.test

