# Copy to `backend/.env` and fill in values (do not commit real secrets).

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional: override REST base if it differs from LIVEKIT_URL
# LIVEKIT_REST_URL=https://your-project.livekit.cloud

OPENAI_API_KEY=

# Voice quality / latency (OpenAI plugin defaults are tuned for streaming agents)
# Use pcm to reduce MP3 frame glitches when audio is delivered in small chunks.
# For more natural timbre at higher latency/cost, try: OPENAI_TTS_MODEL=tts-1-hd
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=ash
OPENAI_TTS_SPEED=1.0
OPENAI_TTS_RESPONSE_FORMAT=pcm
# Optional: steer delivery (prosody, pacing) on supported models, e.g. "Speak clearly and conversationally."
# OPENAI_TTS_INSTRUCTIONS=

# Shared secret for Laravel -> Python internal token requests
LIVEKIT_INTERNAL_TOKEN_SECRET=

# Internal API used by the agent (and parity with Laravel signing hostname). Use the same HTTPS
# host as `.env` `APP_URL` / `PYTHON_ACCESSIBLE_APP_URL`. Docker Compose adds:
# extra_hosts: "titin.ai.test:host-gateway"
LARAVEL_INTERNAL_API_URL=https://titin.ai.test
LARAVEL_INTERNAL_API_SECRET=

# Local Herd/other dev HTTPS often uses a cert the container does not trust — set 1 only on dev.
LARAVEL_INTERNAL_SSL_INSECURE=0

# Comma-separated allowed browser origins for Flask CORS
TOKEN_SERVER_CORS_ORIGINS=https://titin.ai.test,http://localhost,http://127.0.0.1

# Skill extraction mode: heuristic | llm | hybrid
CV_SKILL_EXTRACTION_MODE=hybrid
# Parser hardening (optional). Align CV_MAX_DOWNLOAD_BYTES with Laravel upload max (e.g. 10MiB ≈ max:10240 KB).
# CV_MAX_DOWNLOAD_BYTES=10485760
# CV_PDF_MAX_PAGES=50
# CV_PDF_MAX_EXTRACT_CHARS=500000
# CV_DOCX_MAX_XML_BYTES=8388608
# CV_TXT_MAX_BYTES=2097152
# Max chars stored in profile_json.raw_text_excerpt (default 12000, cap 100000).
# CV_PROFILE_RAW_EXCERPT_CHARS=12000
# OPENAI_CV_EXTRACT_MODEL=gpt-4o-mini
